page { background: linear-gradient(135deg, #fce4ec 0%, #f3e5f5 30%, #e8eaf6 60%, #fce4ec 100%); background-size: 400% 400%; animation: gradientShift 20s ease infinite; font-family: -apple-system, sans-serif; min-height: 100vh; }
@keyframes gradientShift { 0%,100%{background-position:0% 50%}50%{background-position:100% 50%} }
